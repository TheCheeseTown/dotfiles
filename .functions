# Create a directory and cd into it
mkcd() {
	mkdir -p "$1" && cd "$1"
}

# Extract common archive formats
extract() {
	case "$1" in
		*.tar.bz2) tar xjf "$1" ;;
		*.tar.gz)  tar xzf "$1" ;;
		*.tar.xz)  tar xJf "$1" ;;
		*.zip)     unzip "$1" ;;
		*.gz)      gunzip "$1" ;;
		*.7z)      7z x "$1" ;;
		*)         echo "extract: unknown format '$1'" >&2; return 1 ;;
	esac
}

# cd to the root of the current git repo
groot() {
	local root
	root=$(git rev-parse --show-toplevel 2>/dev/null) || { echo "Not in a git repo" >&2; return 1; }
	cd "$root"
}
