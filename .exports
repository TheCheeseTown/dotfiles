# Editor
export EDITOR='nvim'
export VISUAL='nvim'

# Larger history, no duplicates
export HISTSIZE=32768
export SAVEHIST=$HISTSIZE       # zsh
export HISTFILESIZE=$HISTSIZE   # bash fallback
[[ -n "$ZSH_VERSION" ]]  && setopt HIST_IGNORE_DUPS HIST_IGNORE_SPACE
[[ -n "$BASH_VERSION" ]] && export HISTCONTROL=ignoredups

# Locale
export LANG='en_US.UTF-8'
export LC_ALL='en_US.UTF-8'

# Don't litter __pycache__ when running scripts directly
export PYTHONDONTWRITEBYTECODE=1
